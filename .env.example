# Copy to .env for local dev. In production, set these in your hosting
# platform's dashboard (Railway/Render/Fly/etc.) — never commit a real .env.

PORT=3000

# Postgres connection string. Railway/Render/Neon/Supabase all give you
# one of these directly in their dashboard after creating a database.
DATABASE_URL=postgres://user:password@host:5432/dbname
# Set to false only for a local Postgres without SSL.
PGSSL=true

# Dodo Payments — Dashboard → Developer → API Keys
DODO_PAYMENTS_API_KEY=
# test_mode while wiring things up, live_mode when ready for real charges
DODO_ENV=test_mode
# Dashboard → Webhooks → (your endpoint) → Secret
DODO_PAYMENTS_WEBHOOK_SECRET=

# Google Cloud Console → APIs & Services → Credentials → OAuth client ID
# (Web application type)
GOOGLE_OAUTH_CLIENT_ID=
